# ── Authentication ────────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# ── NextAuth URL (required in production) ─────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Note: URL-encode any special chars in the password (@ → %40, # → %23, etc.)
DATABASE_URL="postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres"

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_ADMIN_EMAIL=admin@yourdomain.com

# ── Mailchimp Newsletter Sync ──────────────────────────────────────────────────
# Get these from: https://mailchimp.com → Account → Extras → API Keys
# MAILCHIMP_SERVER is the prefix in your API key, e.g. "us21"
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-audience-list-id
MAILCHIMP_SERVER=us21

# ── Admin seed credentials (used only during db:seed) ─────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-in-production
